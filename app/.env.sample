# [Project Info]
PROJECT_NAME=Antidote

# [PostgreSQL & pgvector Config]
POSTGRES_USER=antidote_admin
POSTGRES_PASSWORD=antidote_pass
POSTGRES_DB=antidote_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://antidote_admin:antidote_pass@localhost:5432/antidote_db

# [AI Service Keys]
OPENAI_API_KEY=your_openai_api_key_here
OCR_API_URL=https://your-clova-ocr-endpoint.com
OCR_SECRET_KEY=your_secret_key

# [AI Model Names]
KOELECTRA_BASE_MODEL=monologg/koelectra-base-v3-discriminator
KOELECTRA_SMALL_MODEL=monologg/koelectra-small-v3-discriminator 
BGE_M3_MODEL=BAAI/bge-m3

# [Vector Dimensions]
BGE_M3_DIMENSION=1024
KOELECTRA_BASE_DIMENSION=768
KOELECTRA_SMALL_DIMENSION=512 

# [Model Settings]
MAX_SEQ_LENGTH=512
