# [Project Info]
PROJECT_NAME=Antidote

# [PostgreSQL & pgvector Config]
POSTGRES_USER=antidote_admin
POSTGRES_PASSWORD=antidote_password
POSTGRES_DB=antidote_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql://antidote_admin:antidote_password@localhost:5432/antidote_db

# [AI Service Keys]
OPENAI_API_KEY=your_openai_api_key_here
OCR_API_URL=https://your-clova-ocr-endpoint.com
OCR_SECRET_KEY=your_secret_key

# [AI Model Config]
MODEL_NAME=monologg/koelectra-base-v3-discriminator
MAX_SEQ_LENGTH=512

# [Vector DB Config]
VECTOR_DIMENSION=768